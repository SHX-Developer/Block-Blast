# ─── Public hostname ──────────────────────────────────────────────────────────
# Subdomain you point at the VPS (A-record). Traefik/Let's Encrypt uses this.
DOMAIN=game.example.com

# ─── Telegram bot ─────────────────────────────────────────────────────────────
# Get from @BotFather.
BOT_TOKEN=

# ─── Database ─────────────────────────────────────────────────────────────────
# Any libpq-compatible URL. The bot stores /start activations in a `users` table.
# Example: postgresql://user:pass@db-host:5432/blockblast?sslmode=require
DATABASE_URL=
